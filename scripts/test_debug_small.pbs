#!/bin/bash
#PBS -N jsam_debug_test
#PBS -A UCLB0066
#PBS -q casper@casper-pbs
#PBS -l select=1:ncpus=4:mem=120GB:ngpus=1:gpu_type=a100
#PBS -l walltime=00:30:00
#PBS -j oe
#PBS -o /glade/u/home/sabramian/SAMJax/outputs/test_debug.log

set -euo pipefail
unset XLA_FLAGS

PYTHON=/glade/u/home/sabramian/.conda/envs/jsam/bin/python
SAMJAX=/glade/u/home/sabramian/SAMJax
OUTDIR=/glade/derecho/scratch/sabramian/jsam_test_debug_small_$(date +%s)/snapshots
DEBUGDIR=/glade/derecho/scratch/sabramian/jsam_test_debug_small/debug
O3FILE=/glade/u/home/sabramian/gSAM1.8.7/GLOBAL_DATA/BIN_D/ozone_era5_monthly_201709-201709_GLOBAL.bin

mkdir -p "$OUTDIR" "$DEBUGDIR"
cd "$SAMJAX"

export XLA_PYTHON_CLIENT_ALLOCATOR=platform
export JAX_COMPILATION_CACHE_DIR=/tmp/jax_$$_$(date +%s%N)
mkdir -p "$JAX_COMPILATION_CACHE_DIR"

echo "=== jsam IRMA debug test (5 steps): $(date) ==="

$PYTHON -u scripts/run_irma.py \
    --nsteps          5 \
    --output-interval 5 \
    --out-dir         "$OUTDIR" \
    --casename        jsam_test \
    --rad             rrtmg \
    --nrad            90 \
    --co2             400.0 \
    --o3file          "$O3FILE" \
    --debug-dump-dir  "$DEBUGDIR" \
    --float32 \
    --no-polar-filter \
    --sponge-tau      0 \
    --slm

echo "=== Test done: $(date) ==="
echo "Debug output:"
ls -lh "$DEBUGDIR"
